# Neon Postgres — use the pooled connection for the app (reduces “connection closed” errors).
# Dashboard → Connect → Pooled connection → copy URI, then append if missing:
#   ?sslmode=require&pgbouncer=true&connect_timeout=15
# “Direct connection” URI goes in DIRECT_URL (used by prisma migrate). If you are not using a pooler, set DIRECT_URL to the same value as DATABASE_URL.
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/neondb?sslmode=require&pgbouncer=true&connect_timeout=15"
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/neondb?sslmode=require"

# Optional: phone/other device on LAN hitting http://YOUR_LAN_IP:3000 (fixes webpack-hmr + helps Auth cookie host)
# ALLOWED_DEV_ORIGINS=192.168.0.229

# Auth.js — generate: openssl rand -base64 32
AUTH_SECRET="replace-with-random-secret"

# Public URL of the app (used for fal webhooks)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Optional: operator fal.ai key if users have not saved their own (BYOK). Per-user keys are preferred.
FAL_KEY=""

# Optional: comma-separated endpoint_id prefixes. If set, only these models/workflows run.
# Example: fal-ai/flux,workflows/,openrouter/router/vision (marketing remix vision + motion)
# FAL_MODEL_ALLOWLIST=""
# FAL_MODEL_DENYLIST=""

# Test-phase guardrails
MAX_NODES_PER_GRAPH=64
MAX_RUNS_PER_USER_PER_DAY=50
MAX_CONCURRENT_RUNS_PER_USER=3
# Comma-separated emails; if set, only these users may run workflows (optional)
# ALLOWED_RUN_EMAILS="you@example.com"
