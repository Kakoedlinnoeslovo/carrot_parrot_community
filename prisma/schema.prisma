generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  /// Pooled URL (Neon: “Pooled connection”, host contains `-pooler` or port 6543). Add `?pgbouncer=true&sslmode=require`.
  url       = env("DATABASE_URL")
  /// Direct URL for migrations (Neon: “Direct connection”, non-pooler). If you do not use a pooler, set the same value as DATABASE_URL.
  directUrl = env("DIRECT_URL")
}

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String    @unique
  emailVerified  DateTime?
  passwordHash   String?
  image          String?
  dailyRunCount  Int       @default(0)
  lastRunDay     String? // UTC date YYYY-MM-DD for daily cap reset

  accounts Account[]
  sessions Session[]

  workflows Workflow[]
  runs      Run[]
  likes     Like[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Workflow {
  id               String  @id @default(cuid())
  userId           String
  title            String?
  slug             String? @unique
  graphJson        String
  visibility       String  @default("private") // private | published
  parentWorkflowId String?
  coverImageUrl    String?
  description      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent Workflow?  @relation("Remixes", fields: [parentWorkflowId], references: [id])
  remixes Workflow[] @relation("Remixes")

  versions WorkflowVersion[]
  runs     Run[]
  likes    Like[]
}

model WorkflowVersion {
  id         String   @id @default(cuid())
  workflowId String
  graphJson  String
  label      String?
  createdAt  DateTime @default(now())

  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
}

model Run {
  id         String    @id @default(cuid())
  workflowId String
  userId     String
  status     String // pending | running | succeeded | failed
  error      String?
  startedAt  DateTime  @default(now())
  finishedAt DateTime?

  /// When true, fal_model steps always call fal (no copy from a prior run).
  skipStepReuse Boolean @default(false)
  /// Optional explicit prior run to copy matching steps from; otherwise latest succeeded run is used.
  reuseReferenceRunId String?

  workflow Workflow  @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  steps    RunStep[]
}

model RunStep {
  id            String @id @default(cuid())
  runId         String
  nodeId        String
  status        String // pending | running | succeeded | failed
  falRequestId  String?
  inputsJson    String?
  outputsJson   String?
  error         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  run Run @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@unique([runId, nodeId])
}

model Like {
  id         String   @id @default(cuid())
  userId     String
  workflowId String
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@unique([userId, workflowId])
}
